generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  BUYER
  SELLER
  SHIPPER
  GUEST

  @@map("user_role")
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  DELETED

  @@map("account_status")
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED

  @@map("seller_status")
}

enum ShipperStatus {
  WORKING
  ON_LEAVE

  @@map("shipper_status")
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
  FINANCE_ADMIN

  @@map("admin_role")
}

enum ProductStatus {
  HIDDEN
  AVAILABLE
  OUT_OF_STOCK
  PENDING

  @@map("product_status")
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID
  WAITING_SELLER_CONFIRMATION
  SELLER_CONFIRMED
  SHIPPING
  DELIVERED
  COMPLETED
  CANCELLED
  RETURN_REQUESTED
  REFUNDED

  @@map("order_status")
}

enum ShipmentStatus {
  ASSIGNED
  PICKED_UP
  DELIVERING
  DELIVERED
  RETURNING
  RETURNED

  @@map("shipment_status")
}

enum PaymentMethod {
  ONLINE
  COD

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  WAITING_COD_COLLECTION

  @@map("payment_status")
}

enum WalletBalanceType {
  PENDING
  AVAILABLE
  RESERVED
  WITHDRAWING
  ON_HOLD

  @@map("wallet_balance_type")
}

enum WalletTxnType {
  ORDER_PENDING
  ORDER_RELEASED
  ORDER_REFUNDED
  WITHDRAWAL_REQUESTED
  WITHDRAWAL_COMPLETED
  WITHDRAWAL_FAILED
  WITHDRAWAL_CANCELLED
  RESERVE_HOLD
  RESERVE_RELEASE
  MANUAL_CREDIT
  MANUAL_DEBIT

  @@map("wallet_txn_type")
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED

  @@map("withdrawal_status")
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  REJECTED
  RETURNING
  RECEIVED
  REFUNDED

  @@map("return_status")
}

enum PlatformTxnType {
  ESCROW_IN
  ESCROW_OUT_SELLER
  ESCROW_OUT_REFUND
  FEE_EARNED
  MANUAL_ADJUST

  @@map("platform_txn_type")
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  userId       Int           @id @default(autoincrement()) @map("user_id")
  nickname     String?       @db.VarChar(255)
  email        String        @db.VarChar(255)
  phone        String?       @db.VarChar(20)
  passwordHash String        @map("password_hash")
  role         UserRole
  status       AccountStatus @default(ACTIVE)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz()

  buyerProfile   BuyerProfile?
  sellerProfile  SellerProfile?
  shipperProfile ShipperProfile?
  adminProfile   AdminProfile?

  @@index([role], map: "idx_users_role")
  @@index([status], map: "idx_users_status")
  // Partial unique indexes (WHERE deleted_at IS NULL) are not natively supported
  // by Prisma — manage these via raw SQL migration (already in 001_create_table.sql):
  //   CREATE UNIQUE INDEX uniq_users_email_active ON users (email) WHERE deleted_at IS NULL;
  //   CREATE UNIQUE INDEX uniq_users_phone_active ON users (phone) WHERE deleted_at IS NULL;
  @@map("users")
}

model BuyerProfile {
  buyerId   Int      @id @default(autoincrement()) @map("buyer_id")
  userId    Int      @unique @map("user_id")
  fullName  String   @map("full_name") @db.VarChar(255)
  avatarUrl String?  @map("avatar_url")
  address   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user          User            @relation(fields: [userId], references: [userId], onDelete: Cascade)
  cart          Cart?
  orders        Order[]
  returnRequests ReturnRequest[]

  @@map("buyer_profiles")
}

model SellerProfile {
  sellerId         Int          @id @default(autoincrement()) @map("seller_id")
  userId           Int          @unique @map("user_id")
  storeName        String       @map("store_name") @db.VarChar(255)
  storeDescription String?      @map("store_description")
  platformFeeRate  Decimal      @default(10.00) @map("platform_fee_rate") @db.Decimal(5, 2)
  status           SellerStatus @default(PENDING)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz()

  user             User                  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  products         Product[]
  orders           Order[]
  bankAccounts     SellerBankAccount[]
  wallet           SellerWallet?
  withdrawalRequests WithdrawalRequest[]
  walletJournals   WalletJournal[]
  walletTransactions WalletTransaction[]

  @@map("seller_profiles")
}

model SellerBankAccount {
  bankAccountId Int      @id @default(autoincrement()) @map("bank_account_id")
  sellerId      Int      @map("seller_id")
  bankName      String   @map("bank_name") @db.VarChar(255)
  accountNumber String   @map("account_number") @db.VarChar(50)
  accountName   String   @map("account_name") @db.VarChar(255)
  isPrimary     Boolean  @default(false) @map("is_primary")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  seller             SellerProfile       @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  withdrawalRequests WithdrawalRequest[]

  // Partial unique index on (seller_id) WHERE is_primary = TRUE is managed via raw SQL:
  //   CREATE UNIQUE INDEX idx_seller_primary_bank ON seller_bank_accounts (seller_id) WHERE is_primary = TRUE;
  @@map("seller_bank_accounts")
}

model ShipperProfile {
  shipperId Int           @id @default(autoincrement()) @map("shipper_id")
  userId    Int           @unique @map("user_id")
  status    ShipperStatus @default(WORKING)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user      User       @relation(fields: [userId], references: [userId], onDelete: Cascade)
  shipments Shipment[]

  @@map("shipper_profiles")
}

model AdminProfile {
  adminId   Int       @id @default(autoincrement()) @map("admin_id")
  userId    Int       @unique @map("user_id")
  role      AdminRole
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@map("admin_profiles")
}

model Category {
  categoryId  Int      @id @default(autoincrement()) @map("category_id")
  name        String   @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  products Product[]

  @@map("categories")
}

model Product {
  productId     Int           @id @default(autoincrement()) @map("product_id")
  sellerId      Int           @map("seller_id")
  categoryId    Int?          @map("category_id")
  name          String        @db.VarChar(255)
  description   String
  price         BigInt
  stockQuantity Int?          @map("stock_quantity")
  status        ProductStatus @default(PENDING)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamptz()

  seller     SellerProfile  @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  category   Category?      @relation(fields: [categoryId], references: [categoryId], onDelete: SetNull)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([sellerId], map: "idx_products_seller")
  @@index([categoryId], map: "idx_products_category")
  @@index([status], map: "idx_products_status")
  @@map("products")
}

model ProductImage {
  imageId   Int      @id @default(autoincrement()) @map("image_id")
  productId Int      @map("product_id")
  imageUrl  String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@map("product_images")
}

model Cart {
  cartId    Int      @id @default(autoincrement()) @map("cart_id")
  buyerId   Int      @unique @map("buyer_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  buyer     BuyerProfile @relation(fields: [buyerId], references: [buyerId], onDelete: Cascade)
  cartItems CartItem[]

  @@map("carts")
}

model CartItem {
  cartItemId Int      @id @default(autoincrement()) @map("cart_item_id")
  cartId     Int      @map("cart_id")
  productId  Int      @map("product_id")
  quantity   Int
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  cart    Cart    @relation(fields: [cartId], references: [cartId], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@unique([cartId, productId])
  @@map("cart_items")
}

model Order {
  orderId         Int         @id @default(autoincrement()) @map("order_id")
  buyerId         Int         @map("buyer_id")
  sellerId        Int         @map("seller_id")
  totalAmount     BigInt      @map("total_amount")
  paymentMethod   PaymentMethod @map("payment_method")
  shippingFee     BigInt      @default(0) @map("shipping_fee")
  platformFee     BigInt      @default(0) @map("platform_fee")
  // sellerAmount is a GENERATED ALWAYS AS (total_amount - platform_fee) STORED column.
  // Prisma does not support generated columns natively — read it via raw queries or
  // use a @default / virtual approach. Declared here as optional for read purposes.
  sellerAmount    BigInt?     @map("seller_amount")
  shippingAddress String      @map("shipping_address")
  receiverName    String      @map("receiver_name") @db.VarChar(255)
  receiverPhone   String      @map("receiver_phone") @db.VarChar(20)
  status OrderStatus @default(WAITING_SELLER_CONFIRMATION)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  buyer                 BuyerProfile           @relation(fields: [buyerId], references: [buyerId], onDelete: Cascade)
  seller                SellerProfile          @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  orderItems            OrderItem[]
  shipment              Shipment?
  payments              Payment[]
  paymentProviderEvents PaymentProviderEvent[]
  platformTransactions  PlatformTransaction[]
  walletJournals        WalletJournal[]
  walletTransactions    WalletTransaction[]
  returnRequests        ReturnRequest[]

  @@index([buyerId], map: "idx_orders_buyer")
  @@index([sellerId], map: "idx_orders_seller")
  @@index([status], map: "idx_orders_status")
  @@index([createdAt(sort: Desc)], map: "idx_orders_created_at")
  @@map("orders")
}

model OrderItem {
  orderItemId Int      @id @default(autoincrement()) @map("order_item_id")
  orderId     Int      @map("order_id")
  productId   Int      @map("product_id")
  quantity    Int
  unitPrice   BigInt   @map("unit_price")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  order   Order   @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [productId], onDelete: Cascade)

  @@index([orderId], map: "idx_order_items_order")
  @@map("order_items")
}

model Shipment {
  shipmentId   Int            @id @default(autoincrement()) @map("shipment_id")
  orderId      Int            @unique @map("order_id")
  shipperId    Int?           @map("shipper_id")
  trackingCode String?        @map("tracking_code") @db.VarChar(255)
  status       ShipmentStatus @default(ASSIGNED)
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  order   Order           @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  shipper ShipperProfile? @relation(fields: [shipperId], references: [shipperId], onDelete: SetNull)

  @@index([shipperId], map: "idx_shipments_shipper")
  @@map("shipments")
}

model Payment {
  paymentId     Int           @id @default(autoincrement()) @map("payment_id")
  orderId       Int           @map("order_id")
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  amount        BigInt
  transactionId String?       @unique @map("transaction_id") @db.VarChar(255)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  order Order @relation(fields: [orderId], references: [orderId], onDelete: Cascade)

  @@index([orderId], map: "idx_payments_order")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

model PaymentProviderEvent {
  eventId           Int      @id @default(autoincrement()) @map("event_id")
  provider          String   @db.VarChar(100)
  providerEventId   String   @map("provider_event_id") @db.VarChar(255)
  eventType         String   @map("event_type") @db.VarChar(255)
  orderId           Int?     @map("order_id")
  rawPayload        Json     @map("raw_payload")
  signatureVerified Boolean  @default(false) @map("signature_verified")
  processed         Boolean  @default(false)
  receivedAt        DateTime @default(now()) @map("received_at") @db.Timestamptz()

  order Order? @relation(fields: [orderId], references: [orderId], onDelete: SetNull)

  @@unique([provider, providerEventId])
  @@index([orderId], map: "idx_provider_events_order")
  @@map("payment_provider_events")
}

model PlatformWallet {
  walletId       Int      @id @default(1) @map("wallet_id")
  escrowBalance  BigInt   @default(0) @map("escrow_balance")
  revenueBalance BigInt   @default(0) @map("revenue_balance")
  reserveBalance BigInt   @default(0) @map("reserve_balance")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("platform_wallets")
}

model PlatformTransaction {
  platformTxnId  Int             @id @default(autoincrement()) @map("platform_txn_id")
  txnType        PlatformTxnType @map("txn_type")
  amount         BigInt
  refOrderId     Int?            @map("ref_order_id")
  idempotencyKey String          @unique @map("idempotency_key") @db.VarChar(255)
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz()

  refOrder Order? @relation(fields: [refOrderId], references: [orderId], onDelete: SetNull)

  @@map("platform_transactions")
}

model SellerWallet {
  sellerId           Int      @id @map("seller_id")
  pendingBalance     BigInt   @default(0) @map("pending_balance")
  availableBalance   BigInt   @default(0) @map("available_balance")
  reservedBalance    BigInt   @default(0) @map("reserved_balance")
  withdrawingBalance BigInt   @default(0) @map("withdrawing_balance")
  onHoldBalance      BigInt   @default(0) @map("on_hold_balance")
  lifetimeEarned     BigInt   @default(0) @map("lifetime_earned")
  lifetimeWithdrawn  BigInt   @default(0) @map("lifetime_withdrawn")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  seller SellerProfile @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)

  @@map("seller_wallets")
}

model WithdrawalRequest {
  withdrawalId     Int              @id @default(autoincrement()) @map("withdrawal_id")
  sellerId         Int              @map("seller_id")
  bankAccountId    Int              @map("bank_account_id")
  amount           BigInt
  withdrawalFee    BigInt           @default(0) @map("withdrawal_fee")
  // netPayout is GENERATED ALWAYS AS (amount - withdrawal_fee) STORED — read-only via raw SQL.
  netPayout        BigInt?          @map("net_payout")
  status           WithdrawalStatus @default(PENDING)
  transferReference String?         @map("transfer_reference") @db.VarChar(255)
  providerResponse String?          @map("provider_response")
  providerStatus   String?          @map("provider_status") @db.VarChar(255)
  failureReason    String?          @map("failure_reason")
  retryCount       Int              @default(0) @map("retry_count")
  requestedAt      DateTime         @default(now()) @map("requested_at") @db.Timestamptz()
  processedAt      DateTime?        @map("processed_at") @db.Timestamptz()
  completedAt      DateTime?        @map("completed_at") @db.Timestamptz()
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  seller             SellerProfile       @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  bankAccount        SellerBankAccount   @relation(fields: [bankAccountId], references: [bankAccountId], onDelete: Cascade)
  walletJournals     WalletJournal[]
  walletTransactions WalletTransaction[]

  @@map("withdrawal_requests")
}

model WalletJournal {
  journalId      Int           @id @default(autoincrement()) @map("journal_id")
  sellerId       Int           @map("seller_id")
  txnType        WalletTxnType @map("txn_type")
  totalAmount    BigInt        @map("total_amount")
  idempotencyKey String        @unique @map("idempotency_key") @db.VarChar(255)
  refOrderId     Int?          @map("ref_order_id")
  refWithdrawalId Int?         @map("ref_withdrawal_id")
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  seller         SellerProfile      @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  refOrder       Order?             @relation(fields: [refOrderId], references: [orderId], onDelete: SetNull)
  refWithdrawal  WithdrawalRequest? @relation(fields: [refWithdrawalId], references: [withdrawalId], onDelete: SetNull)
  transactions   WalletTransaction[]

  @@index([sellerId], map: "idx_wallet_journals_seller")
  @@map("wallet_journals")
}

model WalletTransaction {
  walletTxnId     Int               @id @default(autoincrement()) @map("wallet_txn_id")
  txnType         WalletTxnType     @map("txn_type")
  sellerId        Int               @map("seller_id")
  journalId       Int               @map("journal_id")
  affectedBalance WalletBalanceType @map("affected_balance")
  delta           BigInt
  balanceBefore   BigInt            @map("balance_before")
  balanceAfter    BigInt            @map("balance_after")
  refOrderId      Int?              @map("ref_order_id")
  refWithdrawalId Int?              @map("ref_withdrawal_id")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz()

  seller        SellerProfile      @relation(fields: [sellerId], references: [sellerId], onDelete: Cascade)
  journal       WalletJournal      @relation(fields: [journalId], references: [journalId], onDelete: Cascade)
  refOrder      Order?             @relation(fields: [refOrderId], references: [orderId], onDelete: SetNull)
  refWithdrawal WithdrawalRequest? @relation(fields: [refWithdrawalId], references: [withdrawalId], onDelete: SetNull)

  @@index([sellerId], map: "idx_wallet_transactions_seller")
  @@map("wallet_transactions")
}

model ReturnRequest {
  returnId     Int          @id @default(autoincrement()) @map("return_id")
  orderId      Int          @map("order_id")
  buyerId      Int          @map("buyer_id")
  reason       String
  status       ReturnStatus @default(REQUESTED)
  adminNote    String?      @map("admin_note")
  refundAmount BigInt?      @map("refund_amount")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  order Order        @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  buyer BuyerProfile @relation(fields: [buyerId], references: [buyerId], onDelete: Cascade)

  @@index([orderId], map: "idx_returns_order")
  @@map("return_requests")
}

model ProcessedWebhook {
  provider    String   @db.VarChar(255)
  eventId     String   @map("event_id") @db.VarChar(255)
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz()

  @@id([provider, eventId])
  @@map("processed_webhooks")
}
